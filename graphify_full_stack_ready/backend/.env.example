# Graphify backend does not require a Graphify API key.
# Auth controls ONLY the HTTP endpoint exposed to GPT Actions.
GRAPHIFY_AUTH_MODE=none
GRAPHIFY_ACTION_TOKEN=change-me-only-if-auth-mode-bearer
GRAPHIFY_URL_SECRET=change-me-artifact-signing-secret
GRAPHIFY_DATA_DIR=./data
GRAPHIFY_WORK_DIR=./data/workspaces
GRAPHIFY_GRAPH_DIR=./data/graphs
GRAPHIFY_ARTIFACT_DIR=./data/artifacts
GRAPHIFY_AUDIT_LOG=./data/audit.jsonl
GRAPHIFY_ALLOWED_HOSTS=github.com,codeload.github.com,raw.githubusercontent.com,objects.githubusercontent.com
GRAPHIFY_ALLOW_LOCAL_PATH=false
GRAPHIFY_MAX_FILES=5000
GRAPHIFY_MAX_FILE_BYTES=1048576
GRAPHIFY_MAX_TOTAL_BYTES=104857600
GRAPHIFY_JOB_WORKERS=2
GRAPHIFY_CLONE_TIMEOUT_SECONDS=180
GRAPHIFY_URL_TTL_SECONDS=900
# Absolute base URL used to build artifact_url in export responses.
# Required so GPT Actions get a clickable absolute download link. Falls back to request host if unset.
GRAPHIFY_PUBLIC_BASE_URL=
# Service identity / run mode (defaults shown).
GRAPHIFY_SERVICE_NAME=Graphify GPTS Backend
GRAPHIFY_RUN_MODE=worker
# NOTE: live Railway prod overrides — MAX_FILES=20000, MAX_TOTAL_BYTES=524288000 (500MB), URL_TTL_SECONDS=3600.
