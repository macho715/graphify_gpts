FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    GRAPHIFY_DATA_DIR=/data \
    GRAPHIFY_WORK_DIR=/data/workspaces \
    GRAPHIFY_GRAPH_DIR=/data/graphs \
    GRAPHIFY_ARTIFACT_DIR=/data/artifacts \
    GRAPHIFY_AUDIT_LOG=/data/audit.jsonl

RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt
COPY app /app/app
RUN mkdir -p /data/workspaces /data/graphs /data/artifacts
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD curl -fsS http://127.0.0.1:8000/health || exit 1
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
