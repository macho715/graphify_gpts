# Public GPT Action endpoint on Vercel. This facade does not store graph data.
GRAPHIFY_BACKEND_URL=https://graphify.example.com
# Backend token if backend GRAPHIFY_AUTH_MODE=bearer. Leave blank if backend Auth=None.
GRAPHIFY_BACKEND_TOKEN=
# Optional token for GPT Action -> Vercel facade. Leave blank for Auth=None PoC.
GRAPHIFY_FACADE_TOKEN=
