# Graphify GPTS Backend — environment template
# Copy to .env and fill in real values. Do NOT commit .env.

# Authentication
GRAPHIFY_API_KEYS=dev-key-1,dev-key-2
# Master key for /admin endpoints (optional)
GRAPHIFY_ADMIN_KEY=admin-dev-key

# Storage
GRAPHIFY_WORK_ROOT=./var/workspaces
GRAPHIFY_ARTIFACT_ROOT=./var/artifacts
GRAPHIFY_AUDIT_LOG=./var/audit.log

# Artifact signed-URL signing
GRAPHIFY_URL_SECRET=change-me-to-a-long-random-string-at-least-32-chars
GRAPHIFY_URL_TTL_SECONDS=3600

# URL fetcher allowlist (comma-separated hostnames)
GRAPHIFY_ALLOWED_HOSTS=github.com,raw.githubusercontent.com,codeload.github.com,gist.githubusercontent.com

# Build constraints
GRAPHIFY_MAX_BUILD_SECONDS=900
GRAPHIFY_MAX_FILES=20000
GRAPHIFY_MAX_BYTES=524288000

# Graphify CLI binary
GRAPHIFY_CLI_BIN=graphify
